# 複製為 .env.local 做本機開發（勿提交 .env.local）
# 本機 npm run dev 時，瀏覽器會改打同源 /__gas_proxy，由 Vite 轉到下列網址（仍須填，否則無法代理）
VITE_GAS_WEBAPP_URL=https://script.google.com/macros/s/XXXX/exec
VITE_API_KEY=your-secret-key

# 若瀏覽器無法直接呼叫 GAS（CORS），改設代理網址（例如 Cloudflare Worker）
# VITE_API_PROXY_URL=https://your-worker.workers.dev

# GitHub Pages 若為 Project site（網址為 https://user.github.io/repo/），建置時設：
# VITE_BASE=/repo名稱/
